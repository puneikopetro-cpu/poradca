# FinAdvisor SK — Watchdog configuration
# Copy these env vars to Railway service: "watchdog"

# Required
APP_URL=https://finadvisor.sk
TELEGRAM_BOT_TOKEN=8428211519:AAHkiiy7iZdkvc-CMQY97zT5ERGbKoa3eh4

# Your personal Telegram chat ID (get it from @userinfobot)
WATCHDOG_CHAT_ID=YOUR_PERSONAL_CHAT_ID

# How often to check (seconds)
CHECK_INTERVAL=60

# Max response time before slow-alert (ms)
MAX_RESPONSE_MS=5000

# Consecutive fails before Telegram alert
FAIL_THRESHOLD=3

# Railway API (for auto-redeploy)
