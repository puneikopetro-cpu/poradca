# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Dev (SQLite):
# DATABASE_URL=sqlite:///./dev.db

# Production (PostgreSQL via Railway):
DATABASE_URL=postgresql://advisor:advisor_secret@localhost:5432/advisor_db

# ─── SECURITY ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin panel access token (change before production!)
ADMIN_TOKEN=change-me-strong-token

# ─── EMAIL (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=[ Gmail App Password ]
NOTIFY_EMAIL=petropuneiko@gmail.com

# ─── TELEGRAM BOT ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ─── OPENAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── STRIPE ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── APP ──────────────────────────────────────────────────────────────────────
APP_DOMAIN=https://finadvisor.sk

# ─── MAINTENANCE MODE ─────────────────────────────────────────────────────────
# Set to "true" to block public access (owner sees it via ?preview=fa_owner_2024)
MAINTENANCE_MODE=false
